    {
      "parameters": {
        "language": "javaScript",
        "mode": "runOnceForEachItem",
        "jsCode": "const assessment = $json.assessment || {};\nconst normalizeList = (value) => Array.isArray(value)\n  ? value.filter(Boolean).join('\\n')\n  : '';\n\nreturn [{\n  json: {\n    Id: $json.Id,\n    qualification_id: $json.qualification_id || '',\n    qualification_status: assessment.qualification_status || '',\n    website_quality_score: assessment.website_quality_score ?? null,\n    redesign_opportunity_score: assessment.redesign_opportunity_score ?? null,\n    qualification_confidence: assessment.confidence ?? null,\n    qualification_summary: assessment.summary || '',\n    qualification_weak_signals: normalizeList(assessment.weak_signals),\n    qualification_strong_signals: normalizeList(assessment.strong_signals),\n    last_qualified_at: $json.created_at || new Date().toISOString()\n  }\n}];"
      },
