    {
      "parameters": {
        "language": "javaScript",
        "mode": "runOnceForEachItem",
        "jsCode": "const row = $json;\nconst category = String(row.category || '').trim();\n\nreturn [{\n  json: {\n    website_url: String(row.website || '').trim(),\n    industry: category || 'local_business',\n    company_name: String(row.name || '').trim(),\n    lead_id: `scraper-lead-${row.Id}`,\n    source_row_id: String(row.Id),\n    qualification_notes: 'Source table: Scraper Leads'\n  }\n}];"
      },
